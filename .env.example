# ── App ──────────────────────────────────────────────────────────────────────
DEBUG=False
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////app/DB/adaptiq.db

# ── Redis (overridden automatically by docker-compose to redis://redis:6379/0)
REDIS_URL=redis://localhost:6379/0

# ── Nvidia API ────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-...

# ── Qdrant Cloud — O*NET skills collection ────────────────────────────────────
QDRANT_URL=https://<cluster-id>.eu-west-2-0.aws.cloud.qdrant.io
QDRANT_API_KEY=<qdrant-api-key>

# ── Qdrant Cloud — Courses collection ────────────────────────────────────────
QDRANT_COURSES_URL=https://<cluster-id>.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_COURSES_API_KEY=<qdrant-courses-api-key>

# ── Neo4j Aura ────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<neo4j-password>
NEO4J_DATABASE=neo4j

# ── HuggingFace (for sentence-transformers model download) ────────────────────
HF_TOKEN=hf_...

# ── OpenRouter (legacy, optional) ────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free
